// Function to cancel fishing
stock CancelFishing(playerid)
{
	if(FishingWaitState[playerid])
	{
		KillTimer(FishingWaitTimer[playerid]);
		FishingWaitTimer[playerid] = 0;
		FishingWaitState[playerid] = false;
		FishingStarting[playerid] = false;
		
		ClearAnimations(playerid);
		if(IsPlayerAttachedObjectSlotUsed(playerid, 0))
		{
			RemovePlayerAttachedObject(playerid, 0);
		}
		
		// Re-enable checkpoint after canceling fishing
		// The CheckBoatCheckpoints timer will restore boat checkpoint if needed
		
		SendClientMessage(playerid, 0xE74C3CFF, "{E74C3C}[FISHING]{FFFFFF} You stopped fishing.");
	}
}

// Function to stop fishing (called after catch or fail)
stock StopFishing(playerid)
{
	// Hide fishing UI
	HideFishingUI(playerid);
	
	// Reset fishing state
	FishingUI[playerid] = false;
	FishingStarting[playerid] = false;
	PlayerFishingMissCount[playerid] = 0;
	
	// Reset fishing state in RPG system
	CallRemoteFunction("SetPlayerFishingState", "ii", playerid, 0);
	
	// Stop all fishing sounds (reel sound, music, etc.)
	CallRemoteFunction("CleanupPlayerAudioForPlayer", "i", playerid);
	
	// Stop fish movement timer
	if(FishTimer[playerid] != 0)
	{
		KillTimer(FishTimer[playerid]);
		FishTimer[playerid] = 0;
	}
	
	// Clear animations
	ClearAnimations(playerid);
	
	// Remove fishing rod attachment if exists
	if(IsPlayerAttachedObjectSlotUsed(playerid, 0))
	{
		RemovePlayerAttachedObject(playerid, 0);
	}
	
	// Restore player control
	TogglePlayerControllable(playerid, true);
	
	// Re-enable checkpoint after fishing ends (boat checkpoint system will restore it if needed)
	// Note: The CheckBoatCheckpoints timer in fishing_rpg_master.pwn will automatically
	// restore the boat checkpoint if player is still on a fishing boat
}

// Public function that can be called from gamemode
forward SetPlayerFishingLevel(playerid, level);
public SetPlayerFishingLevel(playerid, level)
{
	if(level < 1) level = 1;
	if(level > 10) level = 10;
	
	PlayerFishingLevel[playerid] = level;
	return 1;
}

// Public function to get fishing level (callable from gamemode)
forward GetPlayerFishingLevel(playerid);
public GetPlayerFishingLevel(playerid)
{
	// Get level from RPG system
	return CallRemoteFunction("GetPlayerFishingLevelRPG", "i", playerid);
}

// Public function to check if player is in fishing wait state (callable from fishing_rpg_master)
forward IsPlayerInFishingWaitState(playerid);
public IsPlayerInFishingWaitState(playerid)
{
	return FishingWaitState[playerid] ? 1 : 0;
}

// Public function to check if player is fishing
forward IsPlayerFishing(playerid);
public IsPlayerFishing(playerid)
{
	return FishingStarting[playerid] || FishingWaitState[playerid] || FishingUI[playerid];
}